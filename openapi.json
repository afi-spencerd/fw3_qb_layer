{
  "openapi": "3.1.1",
  "info": {
    "title": "FormulaWeb QuickBooks Agent",
    "description": "Thin translator between the FormulaWeb ERP and QuickBooks Desktop. JSON in, JSON out.",
    "version": "v1"
  },
  "servers": [
    {
      "url": "https://localhost:8462/"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "Fw3.QbAgent.Host"
        ],
        "summary": "Agent health and QuickBooks reachability.",
        "operationId": "GetHealth",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/customers": {
      "get": {
        "tags": [
          "Customers"
        ],
        "summary": "List customers, optionally only those modified at or after 'updatedSince'.",
        "operationId": "ListCustomers",
        "parameters": [
          {
            "name": "updatedSince",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CustomerDto"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Customers"
        ],
        "summary": "Create a customer in QuickBooks. Requires an Idempotency-Key header; replays are safe.",
        "operationId": "CreateCustomer",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCustomerRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CustomerDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "409": {
            "description": "Conflict",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Entity",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/customers/{listId}": {
      "get": {
        "tags": [
          "Customers"
        ],
        "summary": "Fetch a single customer by its QuickBooks ListID.",
        "operationId": "GetCustomer",
        "parameters": [
          {
            "name": "listId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CustomerDto"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateCustomerRequest": {
        "required": [
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 41,
            "type": "string"
          },
          "companyName": {
            "maxLength": 41,
            "type": [
              "null",
              "string"
            ]
          },
          "firstName": {
            "maxLength": 25,
            "type": [
              "null",
              "string"
            ]
          },
          "lastName": {
            "maxLength": 25,
            "type": [
              "null",
              "string"
            ]
          },
          "phone": {
            "maxLength": 21,
            "type": [
              "null",
              "string"
            ]
          },
          "email": {
            "maxLength": 1023,
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "CustomerDto": {
        "required": [
          "listId",
          "editSequence",
          "name"
        ],
        "type": "object",
        "properties": {
          "listId": {
            "type": "string"
          },
          "editSequence": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "fullName": {
            "type": [
              "null",
              "string"
            ]
          },
          "isActive": {
            "type": "boolean"
          },
          "companyName": {
            "type": [
              "null",
              "string"
            ]
          },
          "firstName": {
            "type": [
              "null",
              "string"
            ]
          },
          "lastName": {
            "type": [
              "null",
              "string"
            ]
          },
          "phone": {
            "type": [
              "null",
              "string"
            ]
          },
          "email": {
            "type": [
              "null",
              "string"
            ]
          },
          "timeCreated": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "timeModified": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          }
        }
      },
      "HealthResponse": {
        "required": [
          "qbReachable",
          "companyFileOpen",
          "agentVersion",
          "mode"
        ],
        "type": "object",
        "properties": {
          "qbReachable": {
            "type": "boolean"
          },
          "companyFileOpen": {
            "type": "boolean"
          },
          "companyFilePath": {
            "type": [
              "null",
              "string"
            ]
          },
          "qbVersion": {
            "type": [
              "null",
              "string"
            ]
          },
          "sdkVersion": {
            "type": [
              "null",
              "string"
            ]
          },
          "agentVersion": {
            "type": "string"
          },
          "mode": {
            "type": "string"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKey": {
        "type": "apiKey",
        "description": "Shared secret for the internal ERP->agent network.",
        "name": "X-Api-Key",
        "in": "header"
      }
    }
  },
  "tags": [
    {
      "name": "Fw3.QbAgent.Host"
    },
    {
      "name": "Customers"
    }
  ]
}